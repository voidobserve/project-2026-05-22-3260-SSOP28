 119          // 由定时器调用，adc通道切换
 120          void adc_channel_switch_by_isr(void)
 121          {
 122   1          switch (adc_channel_status)
 123   1          {
 124   2          case ADC_CHANNEL_STATUS_NONE:
 125   2          case ADC_CHANNEL_STATUS_SEL_FUEL_END:
 126   2              // 默认状态或者是已经采集完油量对应的ad值，转换到下一个通道
 127   2              adc_channel_set(ADC_CHANNEL_BATTERY);
 128   2              adc_channel_status = ADC_CHANNEL_STATUS_SEL_BATTERY_BEGIN;
 129   2              break;
 130   2          case ADC_CHANNEL_STATUS_SEL_BATTERY_BEGIN:
 131   2              ADC_CFG0 |= ADC_CHAN0_TRG(0x1); // 触发ADC0转换
 132   2              adc_channel_status = ADC_CHANNEL_STATUS_SEL_BATTERY_END;
 133   2              break;
 134   2          case ADC_CHANNEL_STATUS_SEL_BATTERY_END:
 135   2              adc_channel_set(ADC_CHANNEL_FUEL);
 136   2              adc_channel_status = ADC_CHANNEL_STATUS_SEL_FUEL_BEGIN;
 137   2              break;
 138   2          case ADC_CHANNEL_STATUS_SEL_FUEL_BEGIN:
 139   2              ADC_CFG0 |= ADC_CHAN0_TRG(0x1); // 触发ADC0转换
 140   2              adc_channel_status = ADC_CHANNEL_STATUS_SEL_FUEL_END;
 141   2              break;
 142   2      
 143   2          default:
 144   2              break;
 145   2          }
 146   1      }
