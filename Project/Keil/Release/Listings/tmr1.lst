  44          {
  45   1          // 进入中断设置IP，不可删除
  46   1          __IRQnIPnPush(TMR1_IRQn);
  47   1      
  48   1          // ---------------- 用户函数处理 -------------------
  49   1      
  50   1          // 周期中断
  51   1          if (TMR1_CONH & TMR_PRD_PND(0x1))
  52   1          {
