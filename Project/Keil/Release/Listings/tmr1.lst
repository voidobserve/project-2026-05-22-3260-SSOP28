   1          #include "tmr1.h"
   2          
   3          // 定时器定时周期 (单位:Hz)
   4          // 周期值 = 系统时钟 / 定时器分频 / 频率 - 1
   5          #define TMR1_PERIOD (SYSCLK / 128 / 1000 - 1) // 1000Hz,1ms
   6          
   7          /**
   8           * @brief 配置定时器TMR1，配置完成后，定时器默认关闭
   9           */
  10          void tmr1_config(void)
  11          {
  12   1          __SetIRQnIP(TMR1_IRQn, TMR1_IQn_CFG); // 设置中断优先级（TMR1）
  13   1          __DisableIRQ(TMR1_IRQn);              // 禁用中断
  14   1          IE_EA = 1;                            // 打开总中断
  15   1      
  16   1          TMR_ALLCON = TMR1_CNT_CLR(0x1); // 清除计数值
  17   1      
  18   1          // USER_TO_DO 待优化
  19   1          TMR1_CONL &= ~TMR_PRESCALE_SEL(0x07); // 清除TMR1的预分频配置寄存器
  20   1          TMR1_CONL |= TMR_PRESCALE_SEL(0x07);  // 定时器预分频
  21   1          TMR1_CONL &= ~TMR_MODE_SEL(0x03);     // 清除TMR1的模式配置寄存器
  22   1          TMR1_CONL |= TMR_MODE_SEL(0x01);      // 配置TMR1的模式为计数器模式，最后对系统时钟
             -的脉冲进行计数
  23   1      
  24   1          TMR1_CONH &= ~TMR_PRD_PND(0x01); // 清除TMR1的计数标志位，表示未完成计数
  25   1          TMR1_CONH |= TMR_PRD_IRQ_EN(1);  // 使能TMR1的计数中断
  26   1      
  27   1          // 配置TMR1的计数周期
  28   1          TMR1_PRH = TMR_PERIOD_VAL_H((TMR1_PERIOD >> 8) & 0xFF); // 周期值
  29   1          TMR1_PRL = TMR_PERIOD_VAL_L((TMR1_PERIOD >> 0) & 0xFF);
  30   1      
  31   1          // TMR1_CONL &= ~(TMR_SOURCE_SEL(0x07)); // 清除TMR1的时钟源配置寄存器
  32   1          // TMR1_CONL |= TMR_SOURCE_SEL(0x05);    // 配置TMR1的时钟源，不用任何时钟
  33   1      
  34   1          // 重新给TMR1配置时钟
  35   1          TMR1_CONL &= ~(TMR_SOURCE_SEL(0x07)); // 清除定时器的时钟源配置寄存器
  36   1          TMR1_CONL |= TMR_SOURCE_SEL(0x06);    // 配置定时器的时钟源，使用系统时钟
  37   1      
  38   1          __EnableIRQ(TMR1_IRQn); // 使能中断
  39   1          // IE_EA = 1;              // 打开总中断
  40   1      }
  41          
  42          // TMR1中断服务函数
