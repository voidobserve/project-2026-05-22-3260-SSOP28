              u8 ad_key_get_key_id(void)
              {
                  volatile u16 ad_key_id = 0;       // еҚ•ж¬ЎжҢүй”®ж Үеҝ—
                  adc_sel_pin(ADC_PIN_KEY);         // еҶ…йғЁиҮіе°‘еҚ з”Ё1ms
                  ad_key_id = adc_single_convert(); // зӣҙжҺҘз”ЁеҚ•ж¬ЎиҪ¬жҚў,дёҚеҸ–е№іеқҮеҖј,йҳІжӯўиҜҶеҲ«дёҚеҲ°жҢүй”®
