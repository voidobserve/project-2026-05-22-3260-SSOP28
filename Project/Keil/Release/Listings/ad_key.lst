                  {
                      if (key_val == ad_key_event_table[i][0])
                      {
                          // еҰӮжһңеҫҖ KEY_EVENT жһҡдёҫдёӯж·»еҠ дәҶж–°зҡ„жҢүй”®дәӢд»¶пјҢиҝҷйҮҢжҹҘиЎЁзҡ„ж–№жі•е°ұдјҡеӨұж•
