  16   1          P0_MD1 &= ~GPIO_P07_MODE_SEL(0x03);
  17   1      
  18   1          // 2 档 检测脚
  19   1          P1_PU |= GPIO_P10_PULL_UP(0x01);
  20   1          P1_MD0 &= ~GPIO_P10_MODE_SEL(0x03);
  21   1      
  22   1          // 3 档 检测脚
  23   1          P1_PU |= GPIO_P13_PULL_UP(0x01);
  24   1          P1_MD0 &= ~GPIO_P13_MODE_SEL(0x03);
  25   1      
  26   1          // 4 档 检测脚
