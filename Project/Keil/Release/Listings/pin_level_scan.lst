  33   1      
  34   1          // 6 档 检测脚
  35   1          P2_PU |= GPIO_P27_PULL_UP(0x01);
  36   1          P2_MD1 &= ~GPIO_P27_MODE_SEL(0x03);
  37   1      
  38   1          // 小灯（近光灯） 检测脚
  39   1          P2_MD0 &= ~GPIO_P23_MODE_SEL(0x03);
  40   1      
  41   1          // 大灯（远光灯） 检测脚
